### ---------------------------------------
## Auth
### ---------------------------------------

### Melakukan pendaftaran
# @name PostRegister
POST {{BaseUrl}}auth/register
Content-Type: application/json

{
  "name": "Ivana",
  "username": "{{Username}}",
  "password": "{{Password}}"
}

### Masuk ke layanan
# @name PostLogin
POST {{BaseUrl}}auth/login
Content-Type: application/json

{
  "username": "{{Username}}",
  "password": "{{Password}}"
}

> {%
    client.test("Login returns tokens", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body != null, "Empty response body");
        client.assert(response.body.data != null, "Missing body.data");
        client.assert(response.body.data.authToken, "Missing authToken");
        client.assert(response.body.data.refreshToken, "Missing refreshToken");
    });

    if (response.body && response.body.data) {
        client.global.set("authToken", response.body.data.authToken);
        client.global.set("refreshToken", response.body.data.refreshToken);

        // Ambil userId dari token JWT
        try {
            var tokenParts = String(response.body.data.authToken).split(".");
            if (tokenParts.length >= 2) {
                var payloadB64 = tokenParts[1].replace(/-/g, "+").replace(/_/g, "/");
                while (payloadB64.length % 4 !== 0) payloadB64 += "=";
                var payloadJson = atob(payloadB64);
                var payload = JSON.parse(payloadJson);
                if (payload.userId) client.global.set("userId", payload.userId);
            }
        } catch (e) {
            console.log("Failed to decode JWT userId:", e);
        }
    }
%}

### Refresh Token
# @name PostRefreshToken
POST {{BaseUrl}}auth/refresh-token
Content-Type: application/json

{
  "authToken": "{{authToken}}",
  "refreshToken": "{{refreshToken}}"
}

> {%
    client.test("Refresh token returns tokens", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body.data != null, "Missing body.data");
    });

    if (response.body && response.body.data) {
        client.global.set("authToken", response.body.data.authToken);
        client.global.set("refreshToken", response.body.data.refreshToken);

        // Update userId dari token baru
        try {
            var tokenParts = String(response.body.data.authToken).split(".");
            if (tokenParts.length >= 2) {
                var payloadB64 = tokenParts[1].replace(/-/g, "+").replace(/_/g, "/");
                while (payloadB64.length % 4 !== 0) payloadB64 += "=";
                var payloadJson = atob(payloadB64);
                var payload = JSON.parse(payloadJson);
                if (payload.userId) client.global.set("userId", payload.userId);
            }
        } catch (e) {}
    }
%}

### Keluar dari layanan
# @name PostLogout
POST {{BaseUrl}}auth/logout
Content-Type: application/json

{
  "authToken": "{{authToken}}"
}

### ---------------------------------------
## Users
### ---------------------------------------

### Mengambil informasi akun
# @name GetUserMe
GET {{BaseUrl}}profile
Authorization: Bearer {{authToken}}
Content-Type: application/json

> {%
    if (response.body && response.body.data && response.body.data.id) {
        client.global.set("userId", response.body.data.id);
    }
%}

### Mengubah informasi akun
# @name PutUserMe
PUT {{BaseUrl}}profile
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Ivana Update",
  "username": "ivana23"
}

### Mengubah kata sandi akun
# @name PutUserMePassword
PUT {{BaseUrl}}profile/password
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "newPassword": "{{NewPassword}}",
  "oldPassword": "{{OldPassword}}"
}

### Mengubah foto profil
# @name PutUserMePhoto
PUT {{BaseUrl}}profile/photo
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="profile.png"
Content-Type: image/png

< ./uploads/profile.png
--WebAppBoundary--

### Mengambil foto profil berdasarkan userId
# @name GetMyPhoto
GET {{BaseUrl}}images/users/{{userId}}
Authorization: Bearer {{authToken}}

### ---------------------------------------
## Orders (Laundry)
### ---------------------------------------

### Mengambil semua data pesanan laundry
# @name GetOrders
GET {{BaseUrl}}orders?search=
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Menambahkan pesanan laundry baru
# @name PostOrders
POST {{BaseUrl}}orders
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "customerId": "c123",
  "customerName": "Sarah Jane",
  "contactNumber": "08123456789",
  "serviceType": "Wash & Fold",
  "weightKg": 3.5,
  "status": "New",
  "totalCost": 52500,
  "pickupDate": "2025-03-20",
  "notes": "Jangan dicampur pemutih"
}

> {%
    if (response.body && response.body.data && response.body.data.orderId) {
        client.global.set("orderId", response.body.data.orderId);
    }
%}

### Mengambil pesanan berdasarkan id
# @name GetOrderById
GET {{BaseUrl}}orders/{{orderId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengubah data pesanan
# @name PutOrder
PUT {{BaseUrl}}orders/{{orderId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "customerId": "c123",
  "customerName": "Sarah Jane",
  "contactNumber": "08123456789",
  "serviceType": "Wash & Fold",
  "weightKg": 3.5,
  "status": "Washing",
  "totalCost": 52500,
  "pickupDate": "2025-03-20",
  "notes": "Sedang dicuci"
}

### Menghapus pesanan
# @name DeleteOrder
DELETE {{BaseUrl}}orders/{{orderId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json
